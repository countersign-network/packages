# Copy to .env and fill in. NEVER commit real secrets (.env is gitignored).
# All testnet only — no mainnet keys (prime directive #6).

# --- Cosign Core / front door ---
PORT=8080
COSIGN_URL=http://localhost:8080        # @cosign/mcp uses this for REMOTE mode; unset = embedded

# --- Coinbase Agentic Wallets (packages/providers/coinbase) — see docs/sdk-research/coinbase.md ---
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=
CDP_WALLET_SECRET=

# --- Turnkey (packages/providers/turnkey) — see docs/sdk-research/turnkey.md ---
TURNKEY_API_PUBLIC_KEY=
TURNKEY_API_PRIVATE_KEY=
TURNKEY_ORGANIZATION_ID=

# --- Openfort (packages/providers/openfort) — see docs/sdk-research/openfort.md ---
OPENFORT_SECRET_KEY=
OPENFORT_WALLET_SECRET=

# --- Lithic card rail (packages/providers/lithic) — see docs/sdk-research/lithic.md ---
LITHIC_API_KEY=                          # sandbox key from the Lithic dashboard
# LITHIC_ENV=production                  # default is sandbox (testnet-safe); opt in explicitly
