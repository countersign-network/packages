{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "declaration": true,
    "emitDeclarationOnly": true,
    "composite": false,
    "rootDir": ".",
    "outDir": ".dts",
    "skipLibCheck": true
  },
  "include": [
    "packages/core/src/**/*.ts",
    "api-contract/index.ts",
    "packages/sdk/src/**/*.ts"
  ]
}
