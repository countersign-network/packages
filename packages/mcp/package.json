{
  "name": "@countersign/mcp",
  "version": "0.2.0",
  "description": "Countersign as MCP tools \u2014 the cross-vendor kill switch + spend guard inside any MCP client (Claude, Cursor, \u2026).",
  "mcpName": "io.github.countersign-network/countersign",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "bin": {
    "countersign-mcp": "./dist/server.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "exports": {
      ".": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "build:mcpb": "tsup --config tsup.mcpb.config.ts && npx -y @anthropic-ai/mcpb pack ./mcpb ./countersign.mcpb",
    "start": "tsx src/server.ts",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@countersign/sdk": "workspace:^",
    "@countersign/x402": "workspace:^",
    "@countersign/ap2": "workspace:^",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^4.4.0"
  },
  "devDependencies": {
    "@countersign/api-contract": "workspace:*",
    "@countersign/core": "workspace:*",
    "tsup": "^8.5.1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/countersign-network/packages.git",
    "directory": "packages/mcp"
  },
  "homepage": "https://countersign.network",
  "keywords": [
    "countersign",
    "mcp",
    "model-context-protocol",
    "ai-agents",
    "agent-payments",
    "kill-switch",
    "spend-guard"
  ]
}
