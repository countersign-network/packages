{
  "name": "@countersign/sdk",
  "version": "0.3.0",
  "description": "Countersign SDK — the typed client agents and operators use to wire in the cross-vendor freeze, spend-guard, and live audit ledger. Browser + Node.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "require": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsc -p ../../tsconfig.dts.json && tsup && rollup -c rollup.dts.config.mjs",
    "prepublishOnly": "pnpm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/countersign-network/packages.git",
    "directory": "packages/sdk"
  },
  "homepage": "https://countersign.network",
  "keywords": [
    "countersign",
    "ai-agents",
    "agent-payments",
    "sdk",
    "kill-switch",
    "x402"
  ],
  "dependencies": {
    "@countersign/api-contract": "workspace:^"
  },
  "devDependencies": {
    "@countersign/core": "workspace:*",
    "tsup": "^8.5.1"
  }
}
