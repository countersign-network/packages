{
  "name": "@countersign/api-contract",
  "version": "0.2.0",
  "description": "Countersign Core API contract — typed REST + ws schema and OpenAPI spec for the cross-vendor agent-spend control plane.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./index.ts",
  "types": "./index.ts",
  "exports": {
    ".": "./index.ts",
    "./openapi": "./openapi.yaml"
  },
  "files": ["dist", "openapi.yaml", "LICENSE"],
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "require": "./dist/index.cjs"
      },
      "./openapi": "./openapi.yaml"
    }
  },
  "scripts": {
    "build": "tsc -p ../tsconfig.dts.json && tsup && rollup -c rollup.dts.config.mjs",
    "prepublishOnly": "pnpm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/countersign-network/countersign.git",
    "directory": "api-contract"
  },
  "homepage": "https://countersign.network",
  "keywords": ["countersign", "ai-agents", "agent-payments", "openapi", "policy", "freeze"],
  "dependencies": {
    "zod": "^4.4.0"
  },
  "devDependencies": {
    "@countersign/core": "workspace:*",
    "@countersign/policy": "workspace:*",
    "tsup": "^8.5.1"
  }
}
